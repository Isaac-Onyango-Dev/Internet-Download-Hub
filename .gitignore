# Dependencies — never commit these
node_modules/

# Build outputs — regenerated by npm run build
dist/
release/

# Compiled Electron files — regenerated by build scripts
electron/main.cjs
electron/preload.cjs
electron/preload.js

# Binaries — downloaded automatically by npm run setup:binaries
binaries/

# Test artifacts — regenerated by test runs
playwright-report/
test-results/
coverage/

# Database files — user data, never in source control
*.db
*.db-shm
*.db-wal
downloads.db

# Downloads folder — videos should go to Windows Downloads, not the project
Downloads/

# Environment files — contains secrets
.env
.env.local
.env.production

# Logs
*.log
server_out.log
server_err.log
logs/

# Generated files
folder_structure.txt
tsconfig.tsbuildinfo
node_modules/typescript/tsbuildinfo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.suo
*.user

# Temporary files
*.tmp
*.temp
.cache/