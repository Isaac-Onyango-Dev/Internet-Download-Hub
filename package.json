{
  "name": "internet-download-hub",
  "version": "1.0.2",
  "description": "A free desktop app to download videos from YouTube, Twitter, TikTok, Instagram, and 1000+ other sites",
  "author": {
    "name": "Isaac Onyango",
    "url": "https://github.com/Isaac-Onyango-Dev"
  },
  "homepage": "https://isaac-onyango-dev.github.io/Internet-Download-Hub",
  "repository": {
    "type": "git",
    "url": "https://github.com/Isaac-Onyango-Dev/Internet-Download-Hub.git"
  },
  "bugs": {
    "url": "https://github.com/Isaac-Onyango-Dev/Internet-Download-Hub/issues"
  },
  "license": "MIT",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "postinstall": "npx playwright install chromium",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "dev:main": "npx esbuild electron/main.ts --bundle --platform=node --format=cjs --outfile=electron/main.cjs --external:electron --external:electron-log --external:electron-updater --external:sql.js --external:playwright-core",
    "dev": "npx kill-port 5173 5005 && npx esbuild electron/preload.ts --bundle --platform=node --outfile=electron/preload.cjs --external:electron && concurrently --kill-others-on-fail \"vite\" \"npm run dev:main && wait-on http://localhost:5173 && node scripts/dev-electron.cjs\"",
    "build": "tsx scripts/build.ts && electron-builder build",
    "setup:binaries": "tsx scripts/download-binaries.ts",
    "setup:binaries:force": "tsx scripts/download-binaries.ts --force",
    "build:electron": "npx esbuild electron/main.ts --bundle --platform=node --format=cjs --outfile=electron/main.cjs --external:electron --external:electron-log --external:sql.js --external:playwright-core && npx esbuild electron/preload.ts --bundle --platform=node --outfile=electron/preload.cjs --external:electron",
    "prebuild:win": "vite build && npx esbuild electron/main.ts --bundle --platform=node --format=cjs --define:import.meta.url=undefined --outfile=electron/main.cjs --external:electron --external:electron-log --external:sql.js --external:playwright-core && npx esbuild electron/preload.ts --bundle --platform=node --define:import.meta.url=undefined --outfile=electron/preload.cjs --external:electron",
    "build:win": "npm run setup:binaries && npm run generate:icons && vite build && npm run build:electron && electron-builder build --win",
    "build:mac": "npm run setup:binaries && npm run generate:icons && vite build && npm run build:electron && electron-builder build --mac",
    "build:linux": "npm run setup:binaries && npm run generate:icons && vite build && npm run build:electron && electron-builder build --linux",
    "check": "tsc"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.5",
    "electron-log": "^5.4.3",
    "execa": "^5.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.453.0",
    "playwright-core": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@playwright/test": "^1.58.2",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.60.5",
    "@types/node": "20.19.27",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "chai": "^6.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "date-fns": "^3.6.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.6.0",
    "esbuild": "^0.25.0",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.4",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "build": {
    "appId": "com.internetdownloadhub.app",
    "productName": "Internet Download Hub",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "client/splash.html",
      "electron/main.cjs",
      "electron/preload.cjs",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/sql.js/dist/sql-wasm.js",
      "node_modules/electron-log/**/*",
      "node_modules/playwright-core/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/typescript/**/*",
      "!node_modules/vite/**/*",
      "!node_modules/esbuild/**/*",
      "!node_modules/@types/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/tsx/**/*",
      "!node_modules/postcss/**/*",
      "!node_modules/autoprefixer/**/*",
      "!node_modules/concurrently/**/*",
      "!node_modules/kill-port/**/*",
      "!node_modules/wait-on/**/*",
      "!node_modules/cross-env/**/*",
      "!node_modules/vitest/**/*",
      "!node_modules/@playwright/test/**/*"
    ],
    "asarUnpack": [
      "binaries/yt-dlp.exe",
      "binaries/gallery-dl.exe",
      "binaries/streamlink.exe",
      "binaries/N_m3u8DL-RE.exe",
      "binaries/ffmpeg.exe",
      "binaries/ffprobe.exe",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/playwright-core/.local-browsers/**/*",
      "node_modules/playwright/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "license": "assets/license.txt",
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "en_US",
        "fr_FR",
        "de_DE",
        "es_ES",
        "pt_BR",
        "ar",
        "zh_CN",
        "ja",
        "ko",
        "sw"
      ]
    },
    "extraResources": [
      {
        "from": "binaries/",
        "to": "binaries/",
        "filter": [
          "yt-dlp.exe",
          "gallery-dl.exe",
          "streamlink.exe",
          "N_m3u8DL-RE.exe",
          "ffmpeg.exe",
          "ffprobe.exe"
        ]
      },
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
